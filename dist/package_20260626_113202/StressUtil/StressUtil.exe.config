<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <runtime>
    <!--
      让 .NET Framework 进程跨「处理器组」使用全部逻辑 CPU。
      多路/多核服务器(>64 逻辑处理器)默认只用一个组(<=64)，会导致 CPU 压测
      配置 100% 却只占满一个组(如 64/320 ≈ 20%)。开启后线程分布到所有组、
      Environment.ProcessorCount 返回全部逻辑核数。对 <=64 核机器无副作用。
    -->
    <Thread_UseAllCpuGroups enabled="true" />
    <GCCpuGroup enabled="true" />
    <gcServer enabled="true" />
  </runtime>
</configuration>